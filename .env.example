# =============================================================================
# GAINTIME — Variables d'environnement (template)
# =============================================================================
# Copie ce fichier vers .env pour le développement local :
#   cp .env.example .env
#
# Pour la production, les variables sont passées via docker-compose.prod.yml
# ou directement dans l'environnement du serveur.
# =============================================================================

# --- DJANGO -----------------------------------------------------------------
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
USE_HTTPS_PROXY=False

# --- BASE DE DONNÉES --------------------------------------------------------
# Pour le développement local (PostgreSQL via localhost) :
DATABASE_URL=postgres://wends23:scam2024pass@127.0.0.1:5432/scam

# Pour Docker (le service s'appelle "db") :
# DATABASE_URL=postgres://wends23:scam2024pass@db:5432/scam

# --- REDIS ------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/1

# --- TELEGRAM ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=change-me-to-your-real-telegram-token

# --- SENTRY (optionnel) -----------------------------------------------------
SENTRY_DSN=

# --- VAPID (Web Push — optionnel) -------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=admin@gaintime.com

# --- POSTGRES (pour docker-compose uniquement) ------------------------------
POSTGRES_DB=scam
POSTGRES_USER=wends23
POSTGRES_PASSWORD=scam2024pass

# --- CELERY -----------------------------------------------------------------
CELERY_EAGER=False
